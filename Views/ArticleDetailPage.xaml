<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Rss_feeder_prout.ViewModels"
             xmlns:conv="clr-namespace:Rss_feeder_prout.Converters"
             x:Class="Rss_feeder_prout.ArticleDetailPage"
             x:DataType="vm:ArticleDetailViewModel"
             Shell.NavBarIsVisible="False"
             Shell.PresentationMode="NotAnimated"
             BackgroundColor="{StaticResource Gray950}">

    <ContentPage.Resources>
        <Style x:Key="HoverButtonStyle" TargetType="Button">
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="Scale" Value="1.05" />
                                <Setter Property="Opacity" Value="0.8" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *">

        <Border Grid.Row="0" BackgroundColor="{StaticResource White}" StrokeThickness="0" HeightRequest="60">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1" />
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button Grid.Column="0" Text="◀️" 
                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=OnBackButtonClicked}" 
                        Style="{StaticResource HoverButtonStyle}"
                        BackgroundColor="Transparent" TextColor="{StaticResource Primary}" WidthRequest="60" FontSize="20" />

                <HorizontalStackLayout Grid.Column="2" Spacing="5" Padding="10" VerticalOptions="Center">
                    <Button Text="📤" Command="{Binding ShareCommand}" 
                            Style="{StaticResource HoverButtonStyle}"
                            BackgroundColor="Transparent" FontSize="18" />

                    <Button Text="⭐" 
                        Command="{Binding ArchiveCommand}" 
                        Style="{StaticResource HoverButtonStyle}"
                        BackgroundColor="Transparent" 
                        FontSize="18" 
                        ToolTipProperties.Text="Archiver pour plus tard"/>

                    <Button Text="💾 Sauvegarder" 
                            Command="{Binding DownloadContentCommand}"
                            IsVisible="{Binding Article.IsDownloaded, Converter={StaticResource InverseBoolConverter}}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                            Style="{StaticResource HoverButtonStyle}"
                            BackgroundColor="{StaticResource Secondary}" TextColor="White" CornerRadius="10" FontSize="12" />

                    <Button Text="🌐" 
                            Command="{Binding OpenExternalCommand}"
                            Style="{StaticResource HoverButtonStyle}"
                            BackgroundColor="{StaticResource Gray200}" TextColor="{StaticResource Gray900}" CornerRadius="10" FontSize="12" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <Grid Grid.Row="1">

            <ScrollView>
                <VerticalStackLayout Padding="15" Spacing="0" HorizontalOptions="Center" MaximumWidthRequest="800">

                    

                    <VerticalStackLayout IsVisible="{Binding Article.ContentHtml, Converter={StaticResource NullToBoolConverter}}">

                        <Border StrokeShape="RoundRectangle 15" StrokeThickness="0" BackgroundColor="{StaticResource White}" Margin="0,10,0,20">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.1" />
                            </Border.Shadow>

                            <VerticalStackLayout>
                                <Image Source="{Binding Article.ImageUrl}" Aspect="AspectFill" HeightRequest="280" HorizontalOptions="Fill"
                                       IsVisible="{Binding Article.ImageUrl, Converter={StaticResource NullToBoolConverter}}" />

                                <VerticalStackLayout Padding="20" Spacing="15">
                                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                        <Border BackgroundColor="{StaticResource Primary}" StrokeShape="RoundRectangle 5" Padding="5,2">
                                            <Label Text="{Binding Article.SiteName}" TextColor="White" FontSize="10" FontAttributes="Bold" />
                                        </Border>
                                        <Label Text="{Binding Article.PublishDate, StringFormat='• {0:dd MMMM yyyy}'}" TextColor="{StaticResource Gray500}" FontSize="12" />
                                    </HorizontalStackLayout>

                                    <Label Text="{Binding Article.Title}" FontSize="26" FontAttributes="Bold" TextColor="{StaticResource Gray900}" LineBreakMode="WordWrap" />

                                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

                                    <Grid MinimumHeightRequest="600">
                                        <WebView HorizontalOptions="Fill" VerticalOptions="FillAndExpand">
                                            <WebView.Source>
                                                <HtmlWebViewSource Html="{Binding Article.ContentHtml}" />
                                            </WebView.Source>
                                        </WebView>
                                    </Grid>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <Label Text="Fin de l'article" HorizontalOptions="Center" TextColor="{StaticResource Gray400}" FontSize="12" Margin="0,0,0,30" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>

            <Grid IsVisible="{Binding IsBusy}" BackgroundColor="{StaticResource Gray950}" Opacity="0.8">
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="15">
                    <ActivityIndicator IsRunning="True" Color="{StaticResource Primary}" HeightRequest="50" WidthRequest="50" />
                    <Label Text="Chargement du contenu complet..." TextColor="White" FontAttributes="Italic" />
                </VerticalStackLayout>
            </Grid>

        </Grid>
    </Grid>
</ContentPage>